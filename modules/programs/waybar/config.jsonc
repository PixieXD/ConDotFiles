[
  {
    "position": "top",
    "modules-left": [
      "custom/fuzzel",
      "hyprland/workspaces",
      "hyprland/window"
    ],
    "modules-center": [], // ???
    "modules-right": [
      "battery",
      "network",
      "bluetooth",
      "wireplumber",
      "clock"
    ],
    "custom/fuzzel": {
      "on-click": "fuzzel",
      "format": "ïŒ“"
    },
    "hyprland/window": {
      "format": " {title}"
    },
    "battery": {
      "format": "{capacity}% {icon}",
      "format-icons": {
        "default": [
          "َ°‚ژ",
          "َ°پ؛",
          "َ°پ»",
          "َ°پ¼",
          "َ°پ½",
          "َ°پ¾",
          "َ°پ؟",
          "َ°‚€",
          "َ°‚پ",
          "َ°‚‚",
          "َ°پ¹"
